---
// 文件：src/components/Header.astro
const whatsappLink = "https://wa.me/8618872711490";
---

<header class="fixed w-full top-0 z-50 bg-[#0a0a0a]/90 backdrop-blur-md border-b border-white/5 transition-all duration-300">
  <div class="container mx-auto px-6 h-20 flex items-center justify-between">
    
    <a href="/" class="text-white text-2xl font-black tracking-widest flex items-center">
      ROYAL<span class="text-[#D4AF37]">BUDD</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8">
      <a href="/" class="text-sm font-bold text-white hover:text-[#D4AF37] transition-colors uppercase tracking-wider">Home</a>
      <a href="/products" class="text-sm font-bold text-gray-300 hover:text-[#D4AF37] transition-colors uppercase tracking-wider">Products</a>
      
      <div class="group relative py-6">
        <button class="text-sm font-bold text-gray-300 group-hover:text-[#D4AF37] transition-colors uppercase tracking-wider flex items-center">
          Manufacturing
          <svg class="w-4 h-4 ml-1 transform group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div class="absolute top-16 left-0 w-56 bg-[#111111] border border-gray-800 rounded-lg shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
          <div class="py-2 flex flex-col">
            <a href="/manufacturing/china" class="px-5 py-3 text-sm text-gray-300 hover:text-[#D4AF37] hover:bg-white/5 transition-colors">China Base (R&D Hub)</a>
            <a href="/manufacturing/indonesia" class="px-5 py-3 text-sm text-gray-300 hover:text-[#D4AF37] hover:bg-white/5 transition-colors">Indonesia Base</a>
            <a href="/manufacturing/bangladesh" class="px-5 py-3 text-sm text-gray-300 hover:text-[#D4AF37] hover:bg-white/5 transition-colors">Bangladesh Base</a>
          </div>
        </div>
      </div>

      <a href="/compliance" class="text-sm font-bold text-gray-300 hover:text-[#D4AF37] transition-colors uppercase tracking-wider">Compliance & ESG</a>
      <a href="/rd" class="text-sm font-bold text-gray-300 hover:text-[#D4AF37] transition-colors uppercase tracking-wider">R&D</a>

      <div class="group relative py-6">
        <button class="text-sm font-bold text-gray-300 group-hover:text-[#D4AF37] transition-colors uppercase tracking-wider flex items-center">
          News & Blog
          <svg class="w-4 h-4 ml-1 transform group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div class="absolute top-16 left-0 w-40 bg-[#111111] border border-gray-800 rounded-lg shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
          <div class="py-2 flex flex-col">
            <a href="/news" class="px-5 py-3 text-sm text-gray-300 hover:text-[#D4AF37] hover:bg-white/5 transition-colors">Company News</a>
            <a href="/blog" class="px-5 py-3 text-sm text-gray-300 hover:text-[#D4AF37] hover:bg-white/5 transition-colors">Industry Blog</a>
          </div>
        </div>
      </div>
    </nav>

    <div class="hidden lg:block">
      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="flex items-center px-6 py-2.5 bg-green-600 text-white font-bold text-sm uppercase tracking-wider rounded-full hover:bg-green-500 transition-colors shadow-[0_0_15px_rgba(22,163,74,0.3)]">
        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden text-gray-300 hover:text-[#D4AF37] transition-colors focus:outline-none">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-[#0a0a0a] border-t border-gray-800 h-screen overflow-y-auto pb-32">
    <div class="flex flex-col px-6 py-6 space-y-4">
      <a href="/" class="text-lg font-bold text-white border-b border-gray-800 pb-3">Home</a>
      <a href="/products" class="text-lg font-bold text-white border-b border-gray-800 pb-3">Products</a>
      
      <div class="border-b border-gray-800 pb-3">
        <span class="text-lg font-bold text-[#D4AF37] mb-2 block">Global Manufacturing</span>
        <div class="flex flex-col pl-4 space-y-2">
          <a href="/manufacturing/china" class="text-gray-300">China Base (R&D)</a>
          <a href="/manufacturing/indonesia" class="text-gray-300">Indonesia Base</a>
          <a href="/manufacturing/bangladesh" class="text-gray-300">Bangladesh Base</a>
        </div>
      </div>
      
      <a href="/compliance" class="text-lg font-bold text-white border-b border-gray-800 pb-3">Compliance & ESG</a>
      <a href="/rd" class="text-lg font-bold text-white border-b border-gray-800 pb-3">R&D & Customization</a>
      
      <div class="border-b border-gray-800 pb-3">
        <span class="text-lg font-bold text-[#D4AF37] mb-2 block">News & Blog</span>
        <div class="flex flex-col pl-4 space-y-2">
          <a href="/news" class="text-gray-300">Company News</a>
          <a href="/blog" class="text-gray-300">Industry Blog</a>
        </div>
      </div>

      <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="mt-6 flex justify-center items-center px-6 py-4 bg-green-600 text-white font-bold text-lg uppercase rounded-lg shadow-lg">
        <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Chat on WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconPath = document.getElementById('menu-icon-path');

  btn.addEventListener('click', () => {
    // 切换隐藏状态
    menu.classList.toggle('hidden');
    
    // 切换汉堡图标 (三横线) 和 关闭图标 (X)
    if (menu.classList.contains('hidden')) {
      iconPath.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      iconPath.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });
</script>