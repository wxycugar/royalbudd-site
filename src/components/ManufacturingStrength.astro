---
// 文件：src/components/ManufacturingStrength.astro

const strengths = [
  {
    number: "20+",
    label: "Years of Excellence",
    desc: "Two decades of deep industry expertise in premium bag manufacturing and supply chain optimization.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>`
  },
  {
    number: "2000+",
    label: "Skilled Workforce",
    desc: "A massive, well-trained production team across China and SE Asia ensuring on-time delivery for peak seasons.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>`
  },
  {
    number: "7 Days",
    label: "OEM/ODM Prototyping",
    desc: "Agile R&D centers equipped with 3D modeling and automated cutting, turning concepts into physical samples rapidly.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`
  },
  {
    number: "100%",
    label: "Strict QC Protocol",
    desc: "Rigorous 4-step quality inspection from raw material sourcing to final packaging, guaranteeing zero defects.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>`
  }
];
---

<section class="relative py-24 bg-[#0a0a0a] border-t border-gray-900" id="strength">
  <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none" style="background-image: radial-gradient(#D4AF37 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">Why Choose Us</h2>
      <h3 class="text-3xl md:text-5xl font-bold text-white mb-6">Uncompromising Scale & Precision.</h3>
      <p class="text-gray-400 text-lg">
        We don't just assemble bags; we engineer supply chain solutions. Our infrastructure is built to handle massive volume without sacrificing a single stitch of quality.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {strengths.map((item) => (
        <div class="group relative p-8 bg-[#111111] rounded-2xl border border-gray-800 hover:border-[#D4AF37]/50 transition-all duration-300 overflow-hidden">
          
          <div class="absolute inset-0 bg-gradient-to-br from-[#D4AF37]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <div class="text-gray-600 group-hover:text-[#D4AF37] transition-colors duration-300 mb-6" set:html={item.icon} />
            
            <div class="text-5xl font-extrabold text-white mb-3 tracking-tight">
              {item.number}
            </div>
            
            <h4 class="text-lg font-bold text-[#D4AF37] mb-3">{item.label}</h4>
            <p class="text-gray-400 text-sm leading-relaxed">
              {item.desc}
            </p>
          </div>
          
          <div class="absolute bottom-0 left-0 w-0 h-1 bg-[#D4AF37] group-hover:w-full transition-all duration-500"></div>
        </div>
      ))}
    </div>
  </div>
</section>