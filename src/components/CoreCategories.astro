---
// 文件：src/components/CoreCategories.astro

const categories = [
  {
    title: "Outdoor & Waterproof",
    subtitle: "户外与防水系列",
    products: "Dry Bags, Hiking Backpacks, Tactical Gear",
    tech: "High-frequency welding, 100% Waterproof",
    image: "https://images.unsplash.com/photo-1601662528567-526cd06f6582?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Maternity & Functional",
    subtitle: "母婴与多功能系列",
    products: "Diaper Bags, School Bags, Daily Backpacks",
    tech: "Eco-friendly materials, Smart compartments",
    image: "https://images.unsplash.com/photo-1544816155-12df9643f363?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Premium Urban & Leather",
    subtitle: "都市精品与皮具",
    products: "Women's Totes, Men's Briefcases, Genuine Leather",
    tech: "Precision stitching, Premium hardware",
    image: "https://images.unsplash.com/photo-1584916201218-f4242ceb4809?q=80&w=800&auto=format&fit=crop"
  },
  {
    title: "Heavy-Duty Utility",
    subtitle: "重型工业工具包",
    products: "Tool Bags, Equipment Organizers",
    tech: "Abrasion-resistant fabrics, Reinforced bar-tacks",
    image: "https://images.unsplash.com/photo-1505015920881-0f6174826c36?q=80&w=800&auto=format&fit=crop"
  }
];
---

<section class="py-24 bg-[#111111]" id="categories">
  <div class="container mx-auto px-6">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-12">
      <div class="max-w-2xl">
        <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">Core Manufacturing Capabilities</h2>
        <h3 class="text-3xl md:text-5xl font-bold text-white leading-tight">
          Engineered for Every Demand.
        </h3>
      </div>
      <a href="#contact" class="mt-6 md:mt-0 text-[#D4AF37] hover:text-white font-semibold flex items-center transition-colors group">
        Download Full Catalog 
        <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {categories.map((cat) => (
        <div class="group relative overflow-hidden rounded-xl aspect-[4/5] bg-gray-900 cursor-pointer">
          <img 
            src={cat.image} 
            alt={cat.title} 
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-80 group-hover:opacity-100"
            loading="lazy"
          />
          
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent transition-opacity duration-300"></div>

          <div class="absolute inset-0 p-6 flex flex-col justify-end">
            <div class="translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 mb-4">
              <span class="inline-block px-2 py-1 bg-[#D4AF37] text-black text-[10px] font-bold uppercase tracking-wider rounded mb-2">
                {cat.tech}
              </span>
              <p class="text-gray-300 text-sm leading-relaxed">
                {cat.products}
              </p>
            </div>
            
            <div class="border-l-2 border-[#D4AF37] pl-3">
              <h4 class="text-xl font-bold text-white mb-1">{cat.title}</h4>
              <p class="text-gray-400 text-xs">{cat.subtitle}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>