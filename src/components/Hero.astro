---
// src/components/Hero.astro
import { sanityClient } from "sanity:client";
import { createImageUrlBuilder } from "@sanity/image-url";

const builder = createImageUrlBuilder(sanityClient);
function urlFor(source: any) { return source ? builder.image(source).auto('format') : null; }

// 1. 查询语句：保留标题和电脑端图片的查询
const query = `*[_type == "homePage"][0] {
  heroTitle,
  heroBackgroundImage
}`;

const data = await sanityClient.fetch(query);
const heroImg = data?.heroBackgroundImage ? urlFor(data.heroBackgroundImage) : null;
---

<section class="relative bg-gray-900 text-white pt-24 pb-20 md:pt-32 md:pb-40 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gray-900/70 z-10"></div>

    <picture>
    <source media="(max-width: 767px)" srcset="/hero-bg.webp" />

  <img
    src={heroImg?.width(1200).quality(80).url() ?? ''}
    srcset={heroImg ? `
      ${heroImg.width(600).quality(80).url()} 600w,
      ${heroImg.width(800).quality(80).url()} 800w,
      ${heroImg.width(1200).quality(80).url()} 1200w
    ` : ''}
    sizes="(min-width: 768px) 100vw, 1200px"
    fetchpriority="high"
    loading="eager"
    alt="Royalbudd Global Manufacturing Facility"
    class="w-full h-full object-cover"
  />
</picture>
  </div>

  <div class="relative z-20 container mx-auto px-6 md:px-12">
    <div class="max-w-4xl">
      <p class="text-[#D4AF37] font-bold tracking-[0.2em] uppercase mb-6 text-sm md:text-base">
        China R&D Hub &bull; SE Asia Tax-Free Production
      </p>
      
      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-8">
        {data?.heroTitle ? data.heroTitle : "Global Manufacturing, Localized Innovation."}
      </h1>
      
      <p class="text-lg md:text-xl text-gray-300 mb-12 max-w-2xl leading-relaxed">
        Royalbudd: Defining Bag Aesthetics through 20 Years of Global Craftsmanship. We empower global brands with agile supply chains and scalable bases in Indonesia and Bangladesh.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-5">
        <a href="/request-audit" class="inline-block text-center bg-[#D4AF37] text-gray-900 font-bold py-4 px-10 rounded-sm hover:bg-[#C5A028] transition duration-300 shadow-lg">
          Request Factory Audit
        </a>
      </div>
    </div>
  </div>
</section>