---
// src/components/Hero.astro
// 这里我们引入 Sanity 的客户端工具（如果之前没装，等下可能需要装一下）
import { sanityClient } from "sanity:client";

// 1. 写查询语句：去数据库找 type 为 'homePage' 的文档，把它里面图片的真实网址拿出来
const query = `*[_type == "homePage"][0] {
  heroTitle,
  "imageUrl": heroBackgroundImage.asset->url
}`;

// 2. 执行查询，拿到数据
const data = await sanityClient.fetch(query);

// 3. 准备一个默认的背景色，以防万一图片没加载出来
const bgImageStyle = data?.imageUrl ? `url('${data.imageUrl}')` : 'none';
---

<section class="relative bg-gray-900 text-white pt-24 pb-20 md:pt-32 md:pb-40 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gray-900/70 z-10"></div>
    {data?.imageUrl ? (
       <img
  src={`${data.imageUrl}?fm=webp&q=80&w=1200`}
  srcset={`
    ${data.imageUrl}?fm=webp&q=80&w=600 600w,
    ${data.imageUrl}?fm=webp&q=80&w=800 800w,
    ${data.imageUrl}?fm=webp&q=80&w=1200 1200w
  `}
  sizes="(max-width: 768px) 100vw, 1200px"
  fetchpriority="high"
  loading="eager"
  alt="Royalbudd Global Manufacturing Facility"
  class="w-full h-full object-cover"
/>
    ) : (
      <div class="w-full h-full bg-gray-800"></div>
    )}
  </div>

  <div class="relative z-20 container mx-auto px-6 md:px-12">
    <div class="max-w-4xl">
      <p class="text-[#D4AF37] font-bold tracking-[0.2em] uppercase mb-6 text-sm md:text-base">
        China R&D Hub &bull; SE Asia Tax-Free Production
      </p>
      
      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-8">
        {data?.heroTitle ? data.heroTitle : "Global Manufacturing, Localized Innovation."}
      </h1>
      
      <p class="text-lg md:text-xl text-gray-300 mb-12 max-w-2xl leading-relaxed">
        Royalbudd: Defining Bag Aesthetics through 20 Years of Global Craftsmanship. We empower global brands with agile supply chains and scalable bases in Indonesia and Bangladesh.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-5">
        <a href="/manufacturing" class="inline-block text-center bg-[#D4AF37] text-gray-900 font-bold py-4 px-10 rounded-sm hover:bg-[#C5A028] transition duration-300 shadow-lg">
          Explore Our Capabilities
        </a>
        <a href="/contact" class="inline-block text-center border-2 border-[#D4AF37] text-[#D4AF37] font-bold py-4 px-10 rounded-sm hover:bg-[#D4AF37] hover:text-gray-900 transition duration-300">
          Request Factory Audit
        </a>
      </div>
    </div>
  </div>
</section>