---
// 文件：src/components/GlobalFootprint.astro
---

<section class="relative py-24 bg-[#0a0a0a] overflow-hidden" id="global-footprint">
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#D4AF37]/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-900/20 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">Strategic Supply Chain</h2>
      <h3 class="text-4xl md:text-5xl font-bold text-white mb-6">Zero-Tariff. Infinite Scalability.</h3>
      <p class="text-gray-400 text-lg">
        We engineered a dual-engine supply chain. Combining China's rapid R&D with Southeast Asia's duty-free, massive production capacity to de-risk your sourcing.
      </p>
    </div>

    <div class="relative w-full max-w-5xl mx-auto h-[600px] bg-[#141414] rounded-2xl border border-gray-800 shadow-2xl p-4 md:p-8 flex items-center justify-center overflow-hidden">
      
      <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1000 1000" preserveAspectRatio="none">
        <path 
          d="M 250 200 C 500 200, 500 800, 750 800" 
          fill="none" 
          stroke="#333" 
          stroke-width="3" 
          stroke-dasharray="10 10" 
        />
        <path 
          d="M 250 200 C 500 200, 500 800, 750 800" 
          fill="none" 
          stroke="#D4AF37" 
          stroke-width="4" 
          stroke-dasharray="150 1500"
          class="animate-flow"
        />
      </svg>

      <div class="absolute top-[20%] left-[10%] md:left-[25%] group z-20">
        <div class="relative flex items-center justify-center w-6 h-6">
          <span class="absolute inline-flex w-full h-full rounded-full bg-[#D4AF37] opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full w-3 h-3 bg-[#D4AF37]"></span>
        </div>
        
        <div class="mt-4 w-64 bg-white/5 backdrop-blur-md border border-white/10 rounded-xl p-5 shadow-xl transition duration-300 group-hover:border-[#D4AF37]/50 group-hover:bg-white/10">
         <div class="flex items-center gap-2 mb-2">
            <span class="bg-gray-800 text-[#D4AF37] text-xs font-bold px-2 py-1 rounded border border-gray-700">HUB: CN</span>
            <h4 class="text-white font-bold text-lg">Jiangmen Hub</h4>
          </div>
          <p class="text-[#D4AF37] text-sm font-semibold mb-3">The "Brain" - R&D & Sourcing</p>
          <ul class="space-y-2">
            <li class="flex items-center text-xs text-gray-300">
              <svg class="w-4 h-4 mr-2 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path></svg>
              Rapid Prototyping (7 Days)
            </li>
            <li class="flex items-center text-xs text-gray-300">
              <svg class="w-4 h-4 mr-2 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path></svg>
              Raw Material Consolidation
            </li>
          </ul>
        </div>
      </div>

      <div class="absolute bottom-[20%] right-[10%] md:right-[25%] group z-20">
        <div class="relative flex items-center justify-center w-6 h-6">
          <span class="absolute inline-flex w-full h-full rounded-full bg-[#D4AF37] opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full w-3 h-3 bg-[#D4AF37]"></span>
        </div>
        
        <div class="mt-4 w-72 bg-white/5 backdrop-blur-md border border-white/10 rounded-xl p-5 shadow-xl transition duration-300 group-hover:border-[#D4AF37]/50 group-hover:bg-white/10">
          <div class="flex items-center gap-2 mb-2">
            <span class="bg-gray-800 text-white text-xs font-bold px-2 py-1 rounded border border-gray-700">PLANT: SE</span>
            <h4 class="text-white font-bold text-lg">SE Asia Plants</h4>
          </div>
          <p class="text-[#D4AF37] text-sm font-semibold mb-3">The "Body" - Mass Production</p>
          
          <div class="grid grid-cols-2 gap-2 mb-3">
            <div class="bg-black/40 border border-gray-700 rounded p-2 text-center">
              <span class="block text-xs text-gray-400">Capacity</span>
              <span class="block text-sm font-bold text-white">500k pcs/mo</span>
            </div>
            <div class="bg-[#D4AF37]/20 border border-[#D4AF37]/30 rounded p-2 text-center">
              <span class="block text-xs text-[#D4AF37]">US/EU Tariffs</span>
              <span class="block text-sm font-bold text-[#D4AF37]">0% Duty</span>
            </div>
          </div>

          <p class="text-xs text-gray-400 flex items-center">
             <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
             ISO 9001 & BSCI Certified Facilities
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes flow {
    0% {
      stroke-dashoffset: 1100;
    }
    100% {
      stroke-dashoffset: 0;
    }
  }
  .animate-flow {
    animation: flow 3s linear infinite;
  }
</style>