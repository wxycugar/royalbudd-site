---
// 文件：src/components/GlobalFootprint.astro
---

<section class="relative py-24 bg-[#0a0a0a] overflow-hidden" id="global-footprint">
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[#D4AF37]/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-900/20 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-12 relative">
      <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">Strategic Supply Chain</h2>
      <h3 class="text-4xl md:text-5xl font-bold text-white mb-6">Zero-Tariff. Infinite Scalability.</h3>
      <p class="text-gray-400 text-lg">
        We engineered a dual-engine supply chain. Combining China's rapid R&D with Southeast Asia's duty-free, massive production capacity to de-risk your sourcing.
      </p>
    </div>

    <div class="relative w-full max-w-5xl mx-auto h-[600px] bg-[#141414] rounded-2xl border border-gray-800 shadow-2xl overflow-hidden">
      
      <img 
        src="https://upload.wikimedia.org/wikipedia/commons/8/80/World_map_-_low_resolution.svg" 
        class="absolute inset-0 w-full h-full object-cover opacity-10 pointer-events-none invert z-0" 
        alt="World Map Background" 
      />
      
      <svg class="absolute inset-0 w-full h-full pointer-events-none z-10" viewBox="0 0 1000 1000" preserveAspectRatio="none">
        
        <path 
          d="M 785 410 C 740 410, 740 430, 735 435" 
          fill="none" stroke="#333" stroke-width="3" stroke-dasharray="10 10" 
        />
        <path 
          d="M 785 410 C 820 460, 760 520, 790 560" 
          fill="none" stroke="#333" stroke-width="3" stroke-dasharray="10 10" 
        />
        
        <path 
          d="M 785 410 C 740 410, 740 430, 735 435" 
          fill="none" stroke="#D4AF37" stroke-width="4" stroke-dasharray="150 1500"
          class="animate-flow-BD"
        />
        <path 
          d="M 785 410 C 820 460, 760 520, 790 560" 
          fill="none" stroke="#D4AF37" stroke-width="4" stroke-dasharray="150 1500"
          class="animate-flow-ID"
        />
      </svg>

      <div class="absolute top-[41%] left-[78.5%] z-30">
        <div class="relative flex items-center justify-center w-5 h-5 -translate-x-1/2 -translate-y-1/2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-[#D4AF37] opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full w-2.5 h-2.5 bg-[#D4AF37]"></span>
        </div>
        
        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-48 bg-[#0a0a0a]/90 backdrop-blur-md border border-[#D4AF37]/40 rounded-lg p-3 shadow-lg pointer-events-none">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="bg-gray-800 text-[#D4AF37] text-[10px] font-bold px-1.5 py-0.5 rounded border border-gray-700">HUB: CN</span>
            <h4 class="text-white font-bold text-sm">Jiangmen Hub</h4>
          </div>
          <p class="text-[#D4AF37] text-xs font-semibold">The "Brain" - R&D & Sourcing</p>
        </div>
      </div>

      <div class="absolute top-[43.5%] left-[73.5%] z-30">
        <div class="relative flex items-center justify-center w-5 h-5 -translate-x-1/2 -translate-y-1/2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-blue-500 opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full w-2.5 h-2.5 bg-blue-500"></span>
        </div>
        
        <div class="absolute right-full top-1/2 -translate-y-1/2 mr-3 w-48 bg-[#0a0a0a]/90 backdrop-blur-md border border-blue-500/30 rounded-lg p-3 shadow-lg pointer-events-none">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="bg-gray-800 text-white text-[10px] font-bold px-1.5 py-0.5 rounded border border-gray-700">PLANT: BD</span>
            <h4 class="text-white font-bold text-sm">Bangladesh</h4>
          </div>
          <p class="text-blue-400 text-xs font-semibold mb-2">The "Body" - Mass Production</p>
          <div class="bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded p-1.5 text-center flex justify-between items-center px-3">
            <span class="text-[10px] text-gray-300">US/EU Tariffs</span>
            <span class="text-xs font-bold text-[#D4AF37]">0% Duty</span>
          </div>
        </div>
      </div>

      <div class="absolute top-[56%] left-[79%] z-30">
        <div class="relative flex items-center justify-center w-5 h-5 -translate-x-1/2 -translate-y-1/2">
          <span class="absolute inline-flex w-full h-full rounded-full bg-blue-500 opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full w-2.5 h-2.5 bg-blue-500"></span>
        </div>
        
        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-48 bg-[#0a0a0a]/90 backdrop-blur-md border border-blue-500/30 rounded-lg p-3 shadow-lg pointer-events-none">
          <div class="flex items-center gap-2 mb-1.5">
            <span class="bg-gray-800 text-white text-[10px] font-bold px-1.5 py-0.5 rounded border border-gray-700">PLANT: ID</span>
            <h4 class="text-white font-bold text-sm">Indonesia</h4>
          </div>
          <p class="text-blue-400 text-xs font-semibold mb-2">The "Body" - Mass Production</p>
          <div class="bg-[#D4AF37]/10 border border-[#D4AF37]/30 rounded p-1.5 text-center flex justify-between items-center px-3">
            <span class="text-[10px] text-gray-300">US/EU Tariffs</span>
            <span class="text-xs font-bold text-[#D4AF37]">0% Duty</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes flow-BD {
    0% { stroke-dashoffset: 1650; }
    100% { stroke-dashoffset: 0; }
  }
  @keyframes flow-ID {
    0% { stroke-dashoffset: 1650; }
    100% { stroke-dashoffset: 0; }
  }
  .animate-flow-BD { animation: flow-BD 4s linear infinite; }
  .animate-flow-ID { animation: flow-ID 5s linear infinite; }
</style>