---
// src/components/TrustBar.astro
// 这里可以定义你的证书列表，方便后期维护
const certificates = [
  { name: "BSCI Certified", description: "Social Compliance" },
  { name: "ISO 9001:2015", description: "Quality Management" },
  { name: "SEDEX Members", description: "Ethical Trade" },
  { name: "GRS Certified", description: "Sustainable Materials" }
];
---

<section class="bg-gray-900 border-t border-gray-800 py-10">
  <div class="container mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      
      <div class="text-gray-400 md:w-1/4">
        <p class="text-sm uppercase tracking-widest font-semibold">Trusted by Global Retailers</p>
        <p class="text-xs mt-1">100% Fully Compliant Facilities</p>
      </div>

      <div class="md:w-3/4 grid grid-cols-2 md:grid-cols-4 gap-6 w-full">
        {certificates.map((cert) => (
          <div class="flex flex-col items-center justify-center p-4 border border-gray-800 rounded-sm hover:border-[#D4AF37] hover:bg-gray-800/50 transition-all duration-300 group">
            {/* 这里的 SVG 图标后期可以换成真实的证书 Logo */}
            <svg class="w-8 h-8 text-gray-500 group-hover:text-[#D4AF37] mb-3 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            <span class="text-white font-bold text-sm text-center">{cert.name}</span>
            <span class="text-gray-500 text-xs text-center mt-1">{cert.description}</span>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>