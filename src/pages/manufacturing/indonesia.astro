---
// 文件：src/pages/manufacturing/indonesia.astro
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const pageTitle = "Indonesia Base - Mass Production & Duty-Free | Royalbudd";
---

<Layout title={pageTitle}>
  <main class="bg-[#0a0a0a] min-h-screen">
    
    <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden border-b border-gray-900">
      <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1587293852726-70cdb56c2866?q=80&w=2000&auto=format&fit=crop" alt="Indonesia Factory Exterior" class="w-full h-full object-cover opacity-20" />
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-[#0a0a0a]/80 to-transparent"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10">
        <span class="inline-block py-1 px-3 border border-blue-500 text-blue-500 text-xs font-bold tracking-widest uppercase rounded mb-6">
          Central Java, Indonesia
        </span>
        <h1 class="text-5xl md:text-7xl font-black text-white mb-6 leading-tight tracking-tight">
          The <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-blue-200">Muscle</span> Behind<br/>Mass Production.
        </h1>
        <p class="text-xl text-gray-400 max-w-2xl mb-10 leading-relaxed">
          Our fully compliant, 1000+ worker facility in Central Java is engineered for high-volume execution. Delivering unmatched scale while maximizing your profit margins through strategic GSP trade advantages.
        </p>
      </div>
    </section>

    <section class="py-24 bg-[#111111]">
      <div class="container mx-auto px-6">
        
        <div class="flex flex-col lg:flex-row gap-16 items-center">
          <div class="w-full lg:w-1/2 relative">
            <div class="relative rounded-2xl overflow-hidden border border-gray-800">
              <img src="https://images.unsplash.com/photo-1612803657962-e6e7687f1bf2?q=80&w=1000&auto=format&fit=crop" alt="Sewing Production Line" class="w-full h-[500px] object-cover" />
              <div class="absolute top-6 right-6 bg-black/80 backdrop-blur px-4 py-2 rounded flex items-center border border-gray-700">
                <span class="w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></span>
                <span class="text-white text-sm font-bold tracking-wider">BSCI & ISO 9001</span>
              </div>
            </div>
            <div class="absolute -bottom-10 -right-4 md:-right-10 bg-[#0a0a0a] border border-[#D4AF37]/30 p-8 rounded-xl shadow-2xl z-10">
              <div class="text-[#D4AF37] text-4xl font-black mb-1">1,000+</div>
              <div class="text-gray-400 text-sm font-bold uppercase tracking-wider">Skilled Workers</div>
            </div>
          </div>

          <div class="w-full lg:w-1/2">
            <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">Industrial Scale</h2>
            <h3 class="text-3xl md:text-4xl font-bold text-white mb-8 leading-tight">Built to handle your largest peak-season orders.</h3>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div class="bg-[#0a0a0a] p-6 rounded-xl border border-gray-800">
                <svg class="w-8 h-8 text-blue-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                <div class="text-white font-bold text-xl mb-1">500k pcs / Month</div>
                <div class="text-gray-500 text-sm">Peak Production Capacity</div>
              </div>
              
              <div class="bg-[#0a0a0a] p-6 rounded-xl border border-gray-800">
                <svg class="w-8 h-8 text-blue-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                <div class="text-white font-bold text-xl mb-1">100% Compliant</div>
                <div class="text-gray-500 text-sm">Social & Ethical Audits</div>
              </div>
              
              <div class="bg-[#0a0a0a] p-6 rounded-xl border border-gray-800">
                <svg class="w-8 h-8 text-blue-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <div class="text-white font-bold text-xl mb-1">Automated Lines</div>
                <div class="text-gray-500 text-sm">Computerized Stitching & Cutting</div>
              </div>

              <div class="bg-[#0a0a0a] p-6 rounded-xl border border-gray-800">
                <svg class="w-8 h-8 text-blue-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <div class="text-white font-bold text-xl mb-1">Global Shipping</div>
                <div class="text-gray-500 text-sm">Proximity to Major Ports</div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-24 bg-[#0a0a0a]">
      <div class="container mx-auto px-6">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">Direct Profit Impact</h2>
          <h3 class="text-3xl md:text-5xl font-bold text-white mb-6">Unlock GSP Tariff Benefits.</h3>
          <p class="text-gray-400 text-lg">
            Manufacturing your bags in Indonesia isn't just about labor costs. It's about legally bypassing steep import duties when shipping to North America and Europe.
          </p>
        </div>

        <div class="max-w-4xl mx-auto bg-[#111111] rounded-2xl border border-gray-800 overflow-hidden shadow-2xl">
          <div class="grid grid-cols-1 md:grid-cols-2">
            
            <div class="p-10 border-b md:border-b-0 md:border-r border-gray-800 opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all">
              <div class="flex items-center gap-3 mb-6">
                <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                <h4 class="text-white font-bold text-xl">Standard Import</h4>
              </div>
              <p class="text-gray-400 text-sm mb-8">Shipping standard bags (HTS 4202) from non-preferential regions to the US.</p>
              <div class="bg-black p-4 rounded-lg flex justify-between items-center border border-gray-800">
                <span class="text-gray-500 font-semibold">Typical US Tariff:</span>
                <span class="text-red-500 font-bold text-xl">Up to 20%</span>
              </div>
            </div>

            <div class="p-10 relative bg-gradient-to-br from-[#111111] to-blue-900/10">
              <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-400 to-blue-600"></div>
              <div class="flex items-center gap-3 mb-6">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <h4 class="text-white font-bold text-xl">Indonesia Output</h4>
              </div>
              <p class="text-gray-300 text-sm mb-8">Leveraging Indonesia's Generalized System of Preferences (GSP) status.</p>
              <div class="bg-blue-500/10 p-4 rounded-lg flex justify-between items-center border border-blue-500/30 shadow-[0_0_15px_rgba(59,130,246,0.15)]">
                <span class="text-blue-400 font-semibold">Duty on Eligible Goods:</span>
                <span class="text-blue-400 font-bold text-2xl">0%</span>
              </div>
              <p class="text-[10px] text-gray-600 mt-4 text-center">* Final rates depend on specific material composition and current GSP renewal status.</p>
            </div>

          </div>
        </div>

      </div>
    </section>

    <FinalCTA />
  </main>
  
  <Footer />
</Layout>