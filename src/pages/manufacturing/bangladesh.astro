---
// 文件：src/pages/manufacturing/bangladesh.astro
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';

import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const builder = imageUrlBuilder(sanityClient);
function urlFor(source) {
  return builder.image(source);
}

// 抓取后台数据
const query = `*[_type == "bangladeshPage"][0]`;
let pageData = null;

try {
  pageData = await sanityClient.fetch(query);
} catch (error) {
  console.error("CMS数据连接失败:", error);
}

const pageTitle = "Bangladesh Base - Ultimate Cost Efficiency & EBA | Royalbudd";
---

<Layout title={pageTitle}>
  <main class="bg-[#0a0a0a] min-h-screen">
    
    <section class="relative min-h-[92vh] flex items-center pt-24 pb-12 overflow-hidden border-b border-gray-900">
      
      <div class="absolute inset-0 z-0">
        {pageData?.heroImage ? (
          <img src={urlFor(pageData.heroImage).width(1920).url()} alt="Bangladesh Factory" class="w-full h-full object-cover" />
        ) : (
          <div class="w-full h-full bg-[#0d1110]"></div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] h-28 bottom-0 top-auto"></div>
      </div>

      <div class="container mx-auto px-6 lg:px-12 relative z-10 flex justify-start">
        
        <div class="w-full sm:w-2/3 md:w-1/2 lg:w-[32%] xl:w-[28%] 2xl:w-[26%]">
            
            <div class="relative bg-black/40 backdrop-blur-2xl border border-white/10 px-6 py-10 md:px-8 md:py-12 rounded-2xl shadow-[0_0_35px_rgba(0,0,0,0.45)]">
                
                <span class="inline-block py-1.5 px-3 border border-green-500/40 bg-green-500/10 text-green-300 text-[9px] font-bold tracking-widest uppercase rounded-full mb-5">
                    Dhaka & Sylhet, Bangladesh
                </span>
                
                <h1 class="text-3xl md:text-4xl font-black text-white mb-5 leading-[1.15] tracking-tight">
                    The <span class="text-green-400">Scale</span> to Win Global Tenders.
                </h1>
                
                <p class="text-[13px] text-gray-300 leading-relaxed mb-0 font-light">
                    When price is the deciding factor, our Bangladesh facilities deliver. Engineered for massive volume, deep cost optimization, and duty-free access to the European Union and UK markets.
                </p>
            </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-[#0a0a0a] relative">
      <div class="container mx-auto px-6 relative z-10">
        
        <div class="mb-12">
          <h2 class="text-green-500 font-bold tracking-wider text-sm mb-2 uppercase">Manufacturing Nodes</h2>
          <h3 class="text-3xl md:text-4xl font-bold text-white">Strategic Dual-Facility Setup.</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          
          <div class="bg-[#111111] border border-gray-800 rounded-2xl p-8 md:p-10 hover:border-green-500/30 transition-all hover:-translate-y-1 shadow-lg group">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-[#0a0a0a] border border-gray-800 group-hover:border-green-500/50 rounded-xl flex items-center justify-center text-green-500 transition-colors">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              </div>
              <div>
                <span class="block text-xs text-green-500/70 font-bold uppercase tracking-widest mb-1">Node 01: Dhaka Hub</span>
                <h4 class="text-xl font-bold text-white tracking-wide">PLAYMAX INDUSTRY CO.,LTD</h4>
              </div>
            </div>
            <hr class="border-gray-800 mb-8" />
            <ul class="space-y-5">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-gray-500 mr-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                <p class="text-sm text-gray-400 uppercase leading-relaxed">{pageData?.dhakaAdd || 'Bengal mor, kathgora, Zirabo Ashulia, Dhaka'}</p>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-gray-500 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <span class="text-sm text-gray-300 uppercase"><strong>Director:</strong> {pageData?.dhakaDirector || 'PETER GONG'}</span>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-gray-500 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                <span class="text-sm text-gray-300"><strong>Tel:</strong> {pageData?.dhakaTel || '+8801771336179'}</span>
              </li>
            </ul>
          </div>

          <div class="bg-[#111111] border border-gray-800 rounded-2xl p-8 md:p-10 hover:border-green-500/30 transition-all hover:-translate-y-1 shadow-lg group">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-14 h-14 bg-[#0a0a0a] border border-gray-800 group-hover:border-green-500/50 rounded-xl flex items-center justify-center text-green-500 transition-colors">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              </div>
              <div>
                <span class="block text-xs text-green-500/70 font-bold uppercase tracking-widest mb-1">Node 02: Sylhet Hub</span>
                <h4 class="text-xl font-bold text-white tracking-wide">RIDING HIGH CO.,LTD</h4>
              </div>
            </div>
            <hr class="border-gray-800 mb-8" />
            <ul class="space-y-5">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-gray-500 mr-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                <p class="text-sm text-gray-400 uppercase leading-relaxed">{pageData?.sylhetAdd || 'Alisharkul, Hobigonj Road, P. O: Satgoan, Ward N0.06, Union No.02, Bhunobir, Sreemangal, Moulvibazar-3210'}</p>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-gray-500 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                <span class="text-sm text-gray-300 uppercase"><strong>Director:</strong> {pageData?.sylhetDirector || 'MR. MIAH'}</span>
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-gray-500 mr-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                <span class="text-sm text-gray-300"><strong>Tel:</strong> {pageData?.sylhetTel || '+8801774111119'}</span>
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>

    <section class="py-24 bg-[#111111] border-t border-[#1a1a1a]">
      <div class="container mx-auto px-6">
        
        <div class="flex flex-col lg:flex-row gap-16">
          <div class="lg:w-1/3">
            <div class="sticky top-24">
              <h2 class="text-[#D4AF37] font-bold tracking-wider text-sm mb-4 uppercase">The Bangladesh Edge</h2>
              <h3 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight">Why Sourcing Here?</h3>
              <p class="text-gray-400 leading-relaxed">
                We combine the world's most aggressive labor arbitrage with strategic trade agreements, giving your brand an unbeatable pricing advantage.
              </p>
            </div>
          </div>

          <div class="lg:w-2/3 space-y-6">
            
            <div class="group bg-[#0a0a0a] border border-gray-800 hover:border-green-500/50 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-start md:items-center gap-6 transition-all shadow-xl">
              <div class="w-16 h-16 bg-green-900/20 border border-green-500/20 rounded-full flex-shrink-0 flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div class="flex-grow">
                <h3 class="text-xl font-bold text-white mb-2">{pageData?.ebaTitle || 'EU/UK Duty-Free Access'}</h3>
                <p class="text-gray-400 text-sm leading-relaxed">{pageData?.ebaDesc || 'Bags manufactured in our Bangladesh facilities enter the European Union and the UK completely duty-free under EBA.'}</p>
              </div>
              <div class="bg-[#111111] p-4 rounded-xl border border-gray-800 flex-shrink-0 w-full md:w-auto min-w-[160px] text-left md:text-right">
                <span class="block text-gray-500 text-[10px] uppercase font-bold tracking-wider mb-1">Standard Duty</span>
                <span class="block text-gray-500 line-through mb-1">~9%</span>
                <span class="block text-green-500 font-black text-xl">Our Rate: 0%</span>
              </div>
            </div>

            <div class="group bg-[#0a0a0a] border border-gray-800 hover:border-[#D4AF37]/50 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-start md:items-center gap-6 transition-all shadow-xl">
              <div class="w-16 h-16 bg-[#111111] border border-[#D4AF37]/20 rounded-full flex-shrink-0 flex items-center justify-center group-hover:scale-110 transition-transform">
                <svg class="w-8 h-8 text-[#D4AF37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              </div>
              <div class="flex-grow">
                <h3 class="text-xl font-bold text-white mb-2">{pageData?.laborTitle || 'Aggressive Labor Arbitrage'}</h3>
                <p class="text-gray-400 text-sm leading-relaxed">{pageData?.laborDesc || "Leveraging the world's most competitive labor market. Perfect for labor-intensive products like complex backpacks."}</p>
              </div>
              <div class="bg-[#111111] p-4 rounded-xl border border-gray-800 flex-shrink-0 w-full md:w-auto min-w-[160px] text-left md:text-right">
                <span class="block text-gray-500 text-[10px] uppercase font-bold tracking-wider mb-1">Ideal Output</span>
                <span class="block text-white font-black text-xl">1M+ Pcs</span>
                <span class="block text-[#D4AF37] text-xs font-semibold mt-1">High Volume</span>
              </div>
            </div>

          </div>

        </div>
      </div>
    </section>

    <section class="py-24 bg-[#0a0a0a]">
      <div class="container mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-green-500 font-bold tracking-wider text-sm mb-4 uppercase">Transparent Operations</h2>
          <h3 class="text-3xl md:text-5xl font-bold text-white mb-6">Inside the Powerhouse.</h3>
          <p class="text-gray-400 text-lg">
            We invite you to audit our facilities. Fully compliant with Sedex and BSCI frameworks to ensure your brand's reputation remains pristine.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 h-[600px]">
          <div class="md:col-span-2 relative rounded-xl overflow-hidden group">
            {pageData?.galleryMain ? (
              <img src={urlFor(pageData.galleryMain).width(1200).url()} alt="Main Production Line" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
            ) : (
              <div class="w-full h-full bg-[#111111] flex items-center justify-center text-gray-600 border border-gray-800">等待上传: 左侧大图</div>
            )}
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all"></div>
            <span class="absolute bottom-6 left-6 text-white font-bold tracking-wider text-sm uppercase bg-black/60 px-3 py-1 backdrop-blur">Main Production Line</span>
          </div>

          <div class="grid grid-rows-2 gap-4">
            <div class="relative rounded-xl overflow-hidden group">
              {pageData?.galleryTopRight ? (
                <img src={urlFor(pageData.galleryTopRight).width(600).url()} alt="QC Inspection" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              ) : (
                <div class="w-full h-full bg-[#111111] flex items-center justify-center text-gray-600 border border-gray-800">等待上传: 右上小图</div>
              )}
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all"></div>
              <span class="absolute bottom-4 left-4 text-white font-bold tracking-wider text-xs uppercase bg-black/60 px-2 py-1 backdrop-blur">In-line QC</span>
            </div>
            
            <div class="relative rounded-xl overflow-hidden group">
              {pageData?.galleryBottomRight ? (
                <img src={urlFor(pageData.galleryBottomRight).width(600).url()} alt="Warehouse Loading" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
              ) : (
                <div class="w-full h-full bg-[#111111] flex items-center justify-center text-gray-600 border border-gray-800">等待上传: 右下小图</div>
              )}
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-all"></div>
              <span class="absolute bottom-4 left-4 text-white font-bold tracking-wider text-xs uppercase bg-black/60 px-2 py-1 backdrop-blur">Warehouse Loading</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <FinalCTA />
  </main>
  <Footer />
</Layout>