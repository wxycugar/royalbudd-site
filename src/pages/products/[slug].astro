---
// 文件：src/pages/products/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';
import { PortableText } from "astro-portabletext"; // 用于渲染富文本

import { sanityClient } from "sanity:client";
import imageUrlBuilder from "@sanity/image-url";

const builder = imageUrlBuilder(sanityClient);
function urlFor(source) {
  return builder.image(source);
}

// 1. 定义动态路由：告诉 Astro 后台有哪些产品
export async function getStaticPaths() {
  const products = await sanityClient.fetch(`*[_type == "product"]{ "params": { "slug": slug.current } }`);
  return products;
}

const { slug } = Astro.params;

// 2. 抓取当前产品的完整数据
const query = `*[_type == "product" && slug.current == $slug][0]`;
const product = await sanityClient.fetch(query, { slug });

if (!product) {
  return Astro.redirect('/404');
}

// 预处理画廊图片
const galleryImages = product.gallery ? [product.mainImage, ...product.gallery] : [product.mainImage];
---

<Layout title={`${product.title} - Royalbudd`}>
  <main class="bg-[#0a0a0a] min-h-screen pt-28 pb-24">
    <div class="container mx-auto px-6 max-w-7xl">
      
      <nav class="flex text-gray-600 text-[11px] uppercase tracking-widest mb-10 border-b border-gray-900 pb-5">
        <a href="/" class="hover:text-[#D4AF37]">Home</a>
        <span class="mx-3 text-gray-800">/</span>
        <a href="/products" class="hover:text-[#D4AF37]">Products</a>
        <span class="mx-3 text-gray-800">/</span>
        <span class="text-gray-400">{product.title}</span>
      </nav>

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16 lg:items-stretch mb-24">
        
        <div class="w-full lg:w-1/2 flex flex-col">
            <div class="relative bg-[#111111] border border-gray-800 rounded-2xl p-6 md:p-12 aspect-square flex items-center justify-center overflow-hidden mb-6 flex-grow">
              <img 
                id="mainImage"
                src={urlFor(product.mainImage).width(1000).url()} 
                alt={product.title} 
                class="relative z-10 w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.6)]"
              />
            </div>

            <div class="grid grid-cols-4 gap-4" id="galleryThumbs">
              {galleryImages.map((img, index) => (
                <div class={`gallery-thumb ${index === 0 ? 'active' : ''} bg-[#111111] border border-gray-800 rounded-xl p-2 cursor-pointer aspect-square flex items-center justify-center transition-all`}>
                  <img src={urlFor(img).width(200).url()} alt="Thumb" class="object-contain w-full h-full"/>
                </div>
              ))}
            </div>
        </div>

        <div class="w-full lg:w-1/2 flex flex-col justify-center">
          <h1 class="text-2xl lg:text-3xl font-bold text-gray-100 mb-4 leading-tight">{product.title}</h1>
          <div class="text-3xl font-black text-[#D4AF37] mb-8 border-b border-gray-900 pb-6">
            {product.price || 'Inquire for Price'}
          </div>

          {product.colors && (
            <div class="mb-10">
              <h3 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-4">Colors</h3>
              <div class="flex gap-3">
                {product.colors.map(color => (
                  <div class="w-8 h-8 rounded-full border border-gray-800" style={`background-color: ${color.hex}`} title={color.name}></div>
                ))}
              </div>
            </div>
          )}

          <div class="bg-[#111111] border border-gray-800 rounded-2xl p-7 mb-10">
            <div class="grid grid-cols-2 gap-x-8 gap-y-6">
              {[
                { label: 'MOQ', value: product.moq },
                { label: 'Sample Time', value: product.sampleTime },
                { label: 'Lead Time', value: product.leadTime },
                { label: 'Fabric', value: product.fabric },
                { label: 'Lining', value: product.lining },
                { label: 'Capacity', value: product.capacity },
                { label: 'Size', value: product.size },
                { label: 'Weight', value: product.weight },
              ].map(item => (
                <div class="flex justify-between items-end border-b border-gray-800/60 pb-1.5">
                  <span class="text-gray-500 text-[10px] uppercase tracking-widest font-semibold">{item.label}</span>
                  <span class="text-gray-200 font-bold text-sm">{item.value || '-'}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="flex flex-wrap gap-3 mb-10">
            <span class="bg-[#1a1a1a] border border-gray-700 text-gray-400 px-3 py-1.5 rounded text-xs font-semibold">SKU: {product.sku}</span>
            <span class="bg-[#D4AF37]/10 border border-[#D4AF37]/40 text-[#D4AF37] px-3 py-1.5 rounded text-xs font-bold uppercase tracking-wider">{product.tag2}</span>
            <span class="bg-[#1a1a1a] border border-gray-700 text-gray-300 px-3 py-1.5 rounded text-xs font-semibold uppercase tracking-wider">{product.tag3}</span>
          </div>

          <button class="w-full bg-gradient-to-r from-[#D4AF37] to-[#AA8529] text-black font-black text-lg py-5 rounded-xl uppercase tracking-widest hover:-translate-y-1 transition-all shadow-lg">
            Send Inquiry for Sample
          </button>
        </div>
      </div>

      <div class="mt-24 pt-16 border-t border-gray-900">
        <h2 class="text-2xl font-bold text-white tracking-wide mb-12">Product Specifications</h2>
        <div class="max-w-4xl prose prose-invert prose-lg prose-headings:text-white prose-img:rounded-2xl">
            <PortableText value={product.body} />
        </div>
      </div>

    </div>
  </main>

  <FinalCTA />
  <Footer />

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const mainImage = document.getElementById('mainImage');
        const thumbs = document.querySelectorAll('#galleryThumbs .gallery-thumb');
        thumbs.forEach(thumb => {
            thumb.addEventListener('click', function() {
                mainImage.src = this.querySelector('img').src;
                thumbs.forEach(t => t.classList.remove('active', 'ring-2', 'ring-[#D4AF37]'));
                this.classList.add('active', 'ring-2', 'ring-[#D4AF37]');
            });
        });
    });
  </script>
</Layout>

<style is:inline>
  .gallery-thumb.active { border-color: #555; }
</style>