---
// 文件：src/pages/products/demo.astro
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import FinalCTA from '../../components/FinalCTA.astro';

const pageTitle = "22L Convertible Rolling Backpack - Royalbudd";
---

<Layout title={pageTitle}>
  <main class="bg-[#0a0a0a] min-h-screen pt-28 pb-24">
    <div class="container mx-auto px-6 max-w-7xl">
      
      <nav class="flex text-gray-500 text-xs uppercase tracking-widest mb-10">
        <a href="/" class="hover:text-[#D4AF37] transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/products" class="hover:text-[#D4AF37] transition-colors">Products</a>
        <span class="mx-2">/</span>
        <span class="text-gray-300">22L Convertible Rolling Backpack</span>
      </nav>

      <div class="flex flex-col lg:flex-row gap-16 items-start">
        
        <div class="w-full lg:w-1/2">
          <div class="sticky top-32">
            <div class="bg-[#111111] border border-gray-800 rounded-2xl p-8 md:p-16 flex items-center justify-center relative overflow-hidden group">
              <div class="absolute inset-0 bg-gradient-to-b from-gray-800/20 to-transparent opacity-50"></div>
              
              <img 
                src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=800&auto=format&fit=crop" 
                alt="22L Convertible Rolling Backpack" 
                class="relative z-10 w-full max-w-md object-contain drop-shadow-[0_20px_50px_rgba(0,0,0,0.5)] group-hover:scale-105 transition-transform duration-500"
              />
            </div>

            <div class="grid grid-cols-4 gap-4 mt-6">
              <div class="bg-[#111111] border-2 border-[#D4AF37] rounded-xl p-2 cursor-pointer aspect-square flex items-center justify-center">
                 <img src="https://images.unsplash.com/photo-1553062407-98eeb64c6a62?q=80&w=200&auto=format&fit=crop" class="object-contain w-full h-full opacity-100"/>
              </div>
              <div class="bg-[#111111] border border-gray-800 hover:border-gray-500 rounded-xl p-2 cursor-pointer aspect-square flex items-center justify-center transition-colors">
                 <div class="text-gray-600 text-xs">Image 2</div>
              </div>
              <div class="bg-[#111111] border border-gray-800 hover:border-gray-500 rounded-xl p-2 cursor-pointer aspect-square flex items-center justify-center transition-colors">
                 <div class="text-gray-600 text-xs">Image 3</div>
              </div>
              <div class="bg-[#111111] border border-gray-800 hover:border-gray-500 rounded-xl p-2 cursor-pointer aspect-square flex items-center justify-center transition-colors">
                 <div class="text-gray-600 text-xs">Image 4</div>
              </div>
            </div>
          </div>
        </div>

        <div class="w-full lg:w-1/2">
          
          <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight tracking-tight">
            22L Convertible Rolling Backpack Carry-on Luggage for Business & Travel
          </h1>
          
          <div class="text-3xl font-bold text-[#D4AF37] mb-8">
            $26-$33 <span class="text-lg text-gray-500 font-normal">/ PCS</span>
          </div>

          <div class="mb-10">
            <h3 class="text-gray-500 text-xs font-bold uppercase tracking-widest mb-4">Colors</h3>
            <div class="flex gap-3">
              <button class="w-8 h-8 rounded-full bg-[#F5E6D3] ring-2 ring-offset-2 ring-offset-[#0a0a0a] ring-[#D4AF37] cursor-pointer" title="Khaki"></button>
              <button class="w-8 h-8 rounded-full bg-[#001F7A] ring-1 ring-offset-2 ring-offset-[#0a0a0a] ring-gray-700 hover:ring-gray-400 cursor-pointer" title="Navy"></button>
              <button class="w-8 h-8 rounded-full bg-[#1A1A1A] ring-1 ring-offset-2 ring-offset-[#0a0a0a] ring-gray-700 hover:ring-gray-400 cursor-pointer" title="Black"></button>
            </div>
          </div>

          <div class="bg-[#111111] border border-gray-800 rounded-2xl p-8 mb-10">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-6">
              
              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">MOQ</span>
                <span class="text-white font-bold text-sm">300 Pcs</span>
              </div>
              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Sample Time</span>
                <span class="text-white font-bold text-sm">7-10 days</span>
              </div>

              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Lead Time</span>
                <span class="text-white font-bold text-sm">25-30 days</span>
              </div>
              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Fabric</span>
                <span class="text-white font-bold text-sm">1680D nylon</span>
              </div>

              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Lining</span>
                <span class="text-white font-bold text-sm">210D polyester</span>
              </div>
              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Capacity</span>
                <span class="text-white font-bold text-sm">20L</span>
              </div>

              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Size</span>
                <span class="text-white font-bold text-sm">40 x 30 x 20 cm</span>
              </div>
              <div class="flex justify-between items-end border-b border-gray-800/60 pb-2">
                <span class="text-gray-500 text-xs uppercase tracking-widest font-semibold">Weight</span>
                <span class="text-white font-bold text-sm">1.8kg</span>
              </div>

            </div>
          </div>

          <div class="flex flex-wrap gap-3 mb-10">
            <span class="bg-[#1a1a1a] border border-gray-700 text-gray-400 px-3 py-1.5 rounded text-xs font-semibold tracking-wider">
              SKU: 96028
            </span>
            <span class="bg-[#D4AF37]/10 border border-[#D4AF37]/40 text-[#D4AF37] px-3 py-1.5 rounded text-xs font-bold tracking-wider flex items-center">
              <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              SUPPORT ODM/OEM
            </span>
            <span class="bg-[#1a1a1a] border border-gray-700 text-gray-300 px-3 py-1.5 rounded text-xs font-semibold tracking-wider flex items-center">
              <svg class="w-3.5 h-3.5 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
              BLANK LABEL
            </span>
          </div>

          <button class="w-full bg-gradient-to-r from-[#D4AF37] to-[#AA8529] hover:from-[#E5C048] hover:to-[#BBA040] text-black font-black text-lg py-5 rounded-xl uppercase tracking-widest transition-all transform hover:-translate-y-1 shadow-[0_10px_30px_rgba(212,175,55,0.3)]">
            Send Inquiry for Sample
          </button>

        </div>
      </div>

      <div class="mt-32 pt-16 border-t border-gray-900">
        <div class="flex items-center gap-4 mb-16">
          <h2 class="text-2xl font-bold text-white tracking-wide">Product Specifications</h2>
          <div class="h-[1px] flex-grow bg-gray-900"></div>
        </div>

        <div class="bg-[#0f0f0f] border border-gray-800 rounded-2xl p-10 flex flex-col items-center justify-center min-h-[600px]">
          <h3 class="text-4xl font-black text-gray-700 uppercase tracking-[0.2em] mb-4">Product</h3>
          <div class="h-[2px] w-32 bg-gray-700 mb-4"></div>
          <h3 class="text-4xl font-black text-gray-700 uppercase tracking-[0.2em]">Specifications</h3>
          <p class="text-gray-600 mt-8 max-w-lg text-center">
            (Once connected to CMS, the high-resolution long images uploaded by the operator will be seamlessly rendered here, without margins, creating an immersive product deep-dive.)
          </p>
        </div>
      </div>

    </div>
  </main>

  <FinalCTA />
  <Footer />
</Layout>