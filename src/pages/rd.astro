---
// 文件：src/pages/rd.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import FinalCTA from '../components/FinalCTA.astro';

// 页面 SEO 标题
const pageTitle = "R&D Center | The Innovation Brain of Royalbudd";
---

<Layout title={pageTitle}>
  <main class="bg-[#0a0a0a] min-h-screen">
    
    <section class="relative pt-32 pb-20 overflow-hidden border-b border-gray-900">
      <div class="container mx-auto px-6 relative z-10 text-center">
        <span class="inline-block py-1.5 px-4 border border-[#D4AF37]/40 bg-[#D4AF37]/5 text-[#D4AF37] text-[10px] font-black tracking-[0.3em] uppercase rounded-full mb-8">
            Innovation Hub
        </span>
        <h1 class="text-4xl md:text-7xl font-black text-white mb-8 tracking-tighter leading-none">
            ENGINEERED TO <br/><span class="text-[#D4AF37]">PERFORM.</span>
        </h1>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto leading-relaxed">
            We merge advanced industrial aesthetics with rigorous structural engineering. Our R&D center is where complex global sourcing challenges meet precise manufacturing solutions.
        </p>
      </div>
      <div class="absolute inset-0 z-0 opacity-20 pointer-events-none">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-[#D4AF37]/10 blur-[120px] rounded-full"></div>
      </div>
    </section>

    <section class="py-24 bg-[#0d0d0d]">
      <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="group relative bg-[#111111] border border-gray-800 rounded-3xl overflow-hidden p-10 hover:border-[#D4AF37]/40 transition-all">
            <h3 class="text-2xl font-bold text-white mb-6">Rapid Prototyping Center</h3>
            <p class="text-gray-400 mb-8 leading-relaxed">From 2D sketches to 3D CAD models and physical samples in as fast as 48 hours. Our facility is equipped with advanced laser cutting and precision sewing modules.</p>
            <div class="aspect-video bg-gray-900 rounded-2xl overflow-hidden border border-gray-800">
                <div class="w-full h-full flex items-center justify-center text-gray-700 uppercase tracking-widest text-xs italic">Laboratory Real-shot Image</div>
            </div>
          </div>
          <div class="group relative bg-[#111111] border border-gray-800 rounded-3xl overflow-hidden p-10 hover:border-[#D4AF37]/40 transition-all">
            <h3 class="text-2xl font-bold text-white mb-6">Structural Material Lab</h3>
            <p class="text-gray-400 mb-8 leading-relaxed">Rigorous testing for tensile strength, abrasion resistance, and waterproofing. We ensure every fabric meets the highest global compliance standards.</p>
            <div class="aspect-video bg-gray-900 rounded-2xl overflow-hidden border border-gray-800">
                <div class="w-full h-full flex items-center justify-center text-gray-700 uppercase tracking-widest text-xs italic">Material Testing Image</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 border-t border-gray-900">
      <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row gap-12 items-center">
            <div class="md:w-1/3">
                <h2 class="text-3xl font-black text-white mb-6">The Royalbudd <br/>R&D Workflow.</h2>
                <p class="text-gray-500">Precision is not an accident. It is the result of a disciplined engineering process that bridges design and mass production.</p>
            </div>
            <div class="md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-6">
                {[
                    {step: '01', title: 'Conceptual Design', desc: 'Merging buyer requirements with functional innovation.'},
                    {step: '02', title: 'Structural CAD', desc: 'Precise pattern making and material load analysis.'},
                    {step: '03', title: 'Component Sourcing', desc: 'Global sourcing of hardware and custom fabrics.'},
                    {step: '04', title: 'Master Sample', desc: 'Physical verification of aesthetics and durability.'}
                ].map(item => (
                    <div class="bg-[#111111] p-8 rounded-2xl border-l-4 border-[#D4AF37]">
                        <span class="text-[#D4AF37] font-black text-xs mb-2 block">{item.step}</span>
                        <h4 class="text-white font-bold mb-2">{item.title}</h4>
                        <p class="text-gray-500 text-sm">{item.desc}</p>
                    </div>
                ))}
            </div>
        </div>
      </div>
    </section>

    <FinalCTA />
  </main>
  <Footer />
</Layout>